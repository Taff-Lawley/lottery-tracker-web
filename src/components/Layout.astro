---
import { translations } from '../i18n/translations';
import DownloadSection from './DownloadSection.astro';
import '../styles/global.css';

interface Props {
  title: string;
  lang?: 'en' | 'de' | 'fr';
  noindex?: boolean;
  showDownload?: boolean;
  showLangSwitcher?: boolean;
}

const { title, lang = 'en', noindex = false, showDownload = true, showLangSwitcher = true } = Astro.props;
const t = translations[lang];

const langPaths: Record<string, string> = { en: '/', de: '/de/', fr: '/fr/' };
const faqPaths:  Record<string, string> = { en: '/faq', de: '/de/faq', fr: '/fr/faq' };
const home = langPaths[lang];
---

<!doctype html>
<html lang={lang}>
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title}</title>
  {noindex && <meta name="robots" content="noindex" />}
  <link rel="icon" type="image/png" href="/favicon.png" />
  <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
  <slot name="head" />
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag(...args: unknown[]){ (window as any).dataLayer.push(args); }
    (window as any).gtag = gtag;
    gtag('consent', 'default', {
      analytics_storage: 'denied',
      ad_storage: 'denied',
      ad_user_data: 'denied',
      ad_personalization: 'denied',
      wait_for_update: 500,
    });
  </script>
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-9JEKEP5J11"></script>
  <script>
    (window as any).gtag('js', new Date());
    (window as any).gtag('config', 'G-9JEKEP5J11');
  </script>
</head>
<body>

<nav>
  <div class="nav-inner">
    <a href={home} class="nav-logo">
      <img src="/images/strategy-tracker-logo-48.png" alt="Strategy Tracker logo" />Strategy Tracker
    </a>
    <ul class="nav-links">
      <li><a href={`${home}#features`}>{t.nav_features}</a></li>
      <li><a href={`${home}#download`}>{t.nav_download}</a></li>
      <li><a href={faqPaths[lang]}>{t.nav_faq}</a></li>
      <li><a href="/lotto">Lotto 6aus49</a></li>
    </ul>
    {showLangSwitcher && (
      <select class="lang-select" id="lang-switcher" aria-label="Language">
        <option value="en" selected={lang === 'en'}>English</option>
        <option value="de" selected={lang === 'de'}>Deutsch</option>
        <option value="fr" selected={lang === 'fr'}>Français</option>
      </select>
    )}
  </div>
</nav>

<slot />

{showDownload && <DownloadSection lang={lang} />}

<footer>
  <div class="footer-inner">
    <strong>Strategy Tracker</strong>
    <p>{t.footer_tagline}</p>
    <div class="footer-links">
      <a href={home}>{t.nav_home}</a>
      <a href={faqPaths[lang]}>FAQ</a>
      <a href={`${home}privacy`}>{lang === 'de' ? 'Datenschutz' : lang === 'fr' ? 'Confidentialité' : 'Privacy'}</a>
      <a href={`${home}legal`}>{lang === 'de' ? 'Impressum' : lang === 'fr' ? 'Mentions légales' : 'Legal'}</a>
    </div>
    <p class="footer-copy">&copy; {new Date().getFullYear()} Adrian Lawley. {lang === 'de' ? 'Alle Rechte vorbehalten.' : lang === 'fr' ? 'Tous droits réservés.' : 'All rights reserved.'}</p>
  </div>
</footer>

<script define:vars={{ langPaths, faqPaths }}>
  const sel = document.getElementById('lang-switcher');
  sel?.addEventListener('change', () => {
    const path = window.location.pathname;
    const isFaq = path.includes('faq');
    window.location.href = isFaq ? faqPaths[sel.value] : langPaths[sel.value];
  });
</script>

<div id="cookie-banner" style="display:none">
  <div class="cookie-inner">
    <p>{t.cookie_text} <a href={`${home}privacy`}>{t.cookie_privacy}</a>.</p>
    <div class="cookie-buttons">
      <button class="cookie-btn cookie-btn-accept" id="cookie-accept">{t.cookie_accept}</button>
      <button class="cookie-btn cookie-btn-decline" id="cookie-decline">{t.cookie_decline}</button>
    </div>
  </div>
</div>

<script>
  (function () {
    const consent = localStorage.getItem('cookie_consent');
    if (consent === 'granted') {
      (window as any).gtag('consent', 'update', { analytics_storage: 'granted' });
    } else if (!consent) {
      document.getElementById('cookie-banner')!.style.display = 'block';
    }
    document.getElementById('cookie-accept')?.addEventListener('click', () => {
      localStorage.setItem('cookie_consent', 'granted');
      (window as any).gtag('consent', 'update', { analytics_storage: 'granted' });
      document.getElementById('cookie-banner')!.style.display = 'none';
    });
    document.getElementById('cookie-decline')?.addEventListener('click', () => {
      localStorage.setItem('cookie_consent', 'denied');
      document.getElementById('cookie-banner')!.style.display = 'none';
    });
  })();
</script>

</body>
</html>
