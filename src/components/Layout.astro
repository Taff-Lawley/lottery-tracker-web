---
import { translations } from '../i18n/translations';
import DownloadSection from './DownloadSection.astro';

interface Props {
  title: string;
  lang?: 'en' | 'de' | 'fr';
  noindex?: boolean;
  showDownload?: boolean;
}

const { title, lang = 'en', noindex = false, showDownload = true } = Astro.props;
const t = translations[lang];

const langPaths: Record<string, string> = { en: '/', de: '/de/', fr: '/fr/' };
const faqPaths:  Record<string, string> = { en: '/faq', de: '/de/faq', fr: '/fr/faq' };
const home = langPaths[lang];
---

<!doctype html>
<html lang={lang}>
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title}</title>
  {noindex && <meta name="robots" content="noindex" />}
  <link rel="icon" type="image/png" href="/favicon.png" />
  <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
  <link rel="stylesheet" href="/styles/global.css" />
  <slot name="head" />
</head>
<body>

<nav>
  <div class="nav-inner">
    <a href={home} class="nav-logo">
      <img src="/images/strategy-tracker-logo-48.png" alt="Strategy Tracker logo" />Strategy Tracker
    </a>
    <ul class="nav-links">
      <li><a href={`${home}#features`}>{t.nav_features}</a></li>
      <li><a href={`${home}#download`}>{t.nav_download}</a></li>
      <li><a href={faqPaths[lang]}>{t.nav_faq}</a></li>
    </ul>
    <select class="lang-select" id="lang-switcher" aria-label="Language">
      <option value="en" selected={lang === 'en'}>English</option>
      <option value="de" selected={lang === 'de'}>Deutsch</option>
      <option value="fr" selected={lang === 'fr'}>Français</option>
    </select>
  </div>
</nav>

<slot />

{showDownload && <DownloadSection lang={lang} />}

<footer>
  <strong>Strategy Tracker</strong>
  <p>{t.footer_tagline}</p>
  <div style="margin-top:12px;display:flex;justify-content:center;gap:24px;flex-wrap:wrap">
    <a href={home} style="color:rgba(255,255,255,0.6);font-size:0.85rem">{t.nav_home}</a>
    <a href={faqPaths[lang]} style="color:rgba(255,255,255,0.6);font-size:0.85rem">FAQ</a>
    <a href={`${home}privacy`} style="color:rgba(255,255,255,0.6);font-size:0.85rem">{lang === 'de' ? 'Datenschutz' : lang === 'fr' ? 'Confidentialité' : 'Privacy'}</a>
    <a href={`${home}legal`} style="color:rgba(255,255,255,0.6);font-size:0.85rem">{lang === 'de' ? 'Impressum' : lang === 'fr' ? 'Mentions légales' : 'Legal'}</a>
  </div>
  <p style="margin-top:8px">{t.footer_copy}</p>
</footer>

<script define:vars={{ langPaths, faqPaths }}>
  const sel = document.getElementById('lang-switcher');
  sel?.addEventListener('change', () => {
    const path = window.location.pathname;
    const isFaq = path.includes('faq');
    window.location.href = isFaq ? faqPaths[sel.value] : langPaths[sel.value];
  });
</script>

</body>
</html>
