---
import { translations } from '../i18n/translations';
import DownloadSection from './DownloadSection.astro';
import '../styles/global.css';

interface Props {
  lang: 'en' | 'de' | 'fr';
}

const { lang } = Astro.props;
const t = translations[lang];

const base = 'https://strategy-tracker.lawley.de';
const canonical = lang === 'en' ? `${base}/faq` : `${base}/${lang}/faq`;
const langPaths: Record<string, string> = { en: '/', de: '/de/', fr: '/fr/' };
const faqPaths: Record<string, string> = { en: '/faq', de: '/de/faq', fr: '/fr/faq' };

type FAQItem = { q: string; a: string };
type FAQSection = { heading: string; items: FAQItem[] };
type FAQContent = { title: string; subtitle: string; sections: FAQSection[] };

const content: Record<string, FAQContent> = {
  en: {
    title: 'FAQ & How-To',
    subtitle: 'Everything you need to know about Strategy Tracker and how to use it.',
    sections: [
      {
        heading: 'General',
        items: [
          {
            q: 'What is Expected Value (EV)?',
            a: 'Expected Value is the average return per €1 spent on a lottery ticket, accounting for all prize tiers, the jackpot size, and the probability of winning each tier. An EV of 0.40 means you get back €0.40 on average for every €1 you spend. No lottery has a positive EV — the house always wins — but EV varies significantly with jackpot size. Strategy Tracker shows you when the EV is at its seasonal high, so you at least play at the best available moment.',
          },
          {
            q: 'Does Strategy Tracker help me win more often?',
            a: 'No — and we won\'t pretend otherwise. Every draw is independent and the odds are fixed. No system, tool, or strategy can change the probability that your six numbers match the draw. What Strategy Tracker does is help you understand the true cost of playing, track your results honestly, and — for German Lotto specifically — use the High Number Bias generator to pick combinations that pay more if you win.',
          },
          {
            q: 'How often is the draw data updated?',
            a: 'Results are fetched automatically via GitHub Actions within a few hours of each draw closing. The expected value is recalculated as soon as the next jackpot is announced. You\'ll always see fresh data without needing to refresh.',
          },
          {
            q: 'Which lotteries are supported?',
            a: 'UK National Lottery, German Lotto 6/49, Irish Lotto, Austrian Lotto 6aus45, Swiss Lotto, and Canada Lotto 6/49. More lotteries are on the roadmap.',
          },
          {
            q: 'What is "My Plays"?',
            a: 'My Plays lets you save tickets you\'ve actually purchased — not generated ones. Enter your numbers and the draw date, and the app scores them automatically after each draw, showing your match count and prize class. You can track multi-draw entries too.',
          },
          {
            q: 'What is included in premium?',
            a: 'Premium unlocks all generators, full frequency analysis, birthday bias analysis, pairs & triplets analysis, and access to all supported lotteries. It\'s €4.99/month.',
          },
        ],
      },
      {
        heading: 'How to use the app',
        items: [
          {
            q: 'How do I generate tickets?',
            a: 'Select your lottery from the dropdown at the top of the screen, then tap one of the generator tabs (Random, Balanced Sum, Cold Pick, etc.). Hit the Generate button and your tickets appear instantly. Each method generates a fresh set — tap again to get a new batch.',
          },
          {
            q: 'How do I save a ticket I actually bought?',
            a: 'Tap the My Plays tab, then the + button. Enter your six numbers, the bonus ball, and the draw date. The app will score it automatically once results are in. You can add multi-draw entries if your ticket covers more than one draw.',
          },
          {
            q: 'How do I see how my generated tickets performed?',
            a: 'Tap the Results tab. You\'ll see a breakdown by generator method showing how many numbers each method matched in past draws, your best-ever match count, and any win streaks.',
          },
          {
            q: 'How do I switch between lotteries?',
            a: 'Use the lottery dropdown at the top of any main screen. Your generated tickets and results are stored per lottery, so switching won\'t lose anything.',
          },
          {
            q: 'How do I change the app language?',
            a: 'Go to Account (the person icon) and tap Language. The app supports English, German, and French.',
          },
        ],
      },
      {
        heading: 'Generators',
        items: [
          {
            q: 'Random',
            a: 'Picks numbers randomly within each historical zone (1–9, 10–19, 20–29, 30–39, 40–49) using six zone templates that reflect common draw distributions. It\'s a quick pick that respects how real draws tend to spread across the number range — not just a pure coin-flip across 1–49.',
          },
          {
            q: 'Balanced Sum',
            a: 'The sum of six winning numbers clusters in a predictable range for each lottery — what we call the "sweet spot". This generator only produces tickets whose numbers add up within that range, filtering out combinations that are statistically rarer winners. It doesn\'t change your odds, but it does mean your tickets look more like historical winners.',
          },
          {
            q: 'Cold Pick',
            a: 'Identifies the 10 numbers that have gone the longest without appearing in any draw (the "coldest" numbers), then picks 6 from that pool. It\'s based on the intuition that overdue numbers might be due — though in reality each draw is statistically independent.',
          },
          {
            q: 'Outdated Pick',
            a: 'Picks numbers that used to appear frequently in historical draws but have been rare in the last year. The ranking is based on how much each number\'s recent draw rate has fallen below its all-time rate. These are numbers that were once "hot" but have gone cool.',
          },
          {
            q: 'High Number Bias',
            a: 'The only generator with a genuine EV argument. German Lotto jackpots are split between all winners, so picking less popular combinations increases your expected share of the prize. Most players choose birthdays (1–31) and avoid consecutive numbers — this generator does the opposite: it weights 32–49 at 3× probability, down-weights "lucky" numbers like 7, 11, 13 and 17, and requires at least one consecutive pair per ticket. It wins no more often than any other method, but when it does win, you\'re less likely to share the jackpot. Currently optimised for German Lotto 6/49.',
          },
          {
            q: 'Weighted',
            a: 'Picks 6 numbers at random, but weighted by historical draw frequency. Numbers that have appeared more often in past draws are more likely to be selected — though any number can still appear. Think of it as a frequency-informed quick pick.',
          },
          {
            q: 'Delta',
            a: 'Builds tickets from incremental gaps (deltas) between consecutive numbers rather than picking numbers directly. Gaps are randomly chosen within fixed ranges to ensure the total spread is at least 38, the last number is ≤ 49, and at most 2 numbers overlap with the historically extreme draws. A more unusual approach that produces a different spread pattern to most generators.',
          },
          {
            q: 'Wheel & Cold Wheel',
            a: 'Wheel systems guarantee coverage: if any winning combination of numbers appears within your chosen base pool, at least one of your tickets will contain it. The standard Wheel picks a random pool of base numbers. The Cold Wheel uses the 15 most overdue numbers as the base instead. Three wheel sizes are available: 10-number (20 tickets), 15-number (8 tickets), and 15-number special (12 of 24 tickets). Wheels produce multiple tickets by design — that\'s how the coverage guarantee works.',
          },
          {
            q: 'Least Frequent & Most Frequent',
            a: 'These two generators use zone templates combined with actual draw frequency data to produce tickets biased toward either the least-drawn or the most-drawn numbers in each zone. Least Frequent targets numbers that have appeared the fewest times historically; Most Frequent targets the opposite end.',
          },
        ],
      },
    ],
  },

