const page = content[lang];
---

<!doctype html>
<html lang={lang}>
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{page.title} — Strategy Tracker</title>
  <meta name="description" content={page.subtitle} />
  <link rel="canonical" href={canonical} />
  <link rel="alternate" hreflang="en" href={`${base}/faq`} />
  <link rel="alternate" hreflang="de" href={`${base}/de/faq`} />
  <link rel="alternate" hreflang="fr" href={`${base}/fr/faq`} />
  <link rel="alternate" hreflang="x-default" href={`${base}/faq`} />
  <link rel="icon" type="image/png" href="/favicon.png" />
  <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
  <style>
    .faq-hero {
      background: linear-gradient(135deg, #1a237e 0%, #4527a0 100%);
      color: #fff;
      text-align: center;
      padding: 80px 24px 60px;
    }
    .faq-hero h1 { font-size: clamp(2rem, 5vw, 3rem); font-weight: 900; margin: 0 0 16px; }
    .faq-hero p  { font-size: 1.1rem; opacity: 0.85; max-width: 560px; margin: 0 auto; }

    .faq-body { max-width: 760px; margin: 0 auto; padding: 48px 24px 96px; }

    .faq-section-heading {
      font-size: 1.4rem;
      font-weight: 800;
      color: #1a237e;
      margin: 48px 0 16px;
      padding-bottom: 8px;
      border-bottom: 2px solid #e8eaf6;
    }
    .faq-section-heading:first-child { margin-top: 0; }

    details {
      border: 1px solid #e2e8f0;
      border-radius: 10px;
      margin-bottom: 10px;
      overflow: hidden;
    }
    summary {
      font-weight: 700;
      font-size: 1rem;
      padding: 18px 20px;
      cursor: pointer;
      display: flex;
      justify-content: space-between;
      align-items: center;
      list-style: none;
      color: #1e293b;
      background: #fff;
      transition: background 0.15s;
    }
    summary::-webkit-details-marker { display: none; }
    summary::after {
      content: '+';
      font-size: 1.4rem;
      color: #7c3aed;
      flex-shrink: 0;
      margin-left: 12px;
      transition: transform 0.2s;
    }
    details[open] summary { background: #f5f3ff; }
    details[open] summary::after { content: '−'; }
    details p {
      padding: 0 20px 20px;
      color: #475569;
      line-height: 1.75;
      font-size: 0.97rem;
      margin: 0;
    }
  </style>
</head>

<body>

<!-- NAV -->
<nav>
  <div class="nav-inner">
    <a href={langPaths[lang]} class="nav-logo">
      <img src="/images/strategy-tracker-logo-48.png" alt="Strategy Tracker logo" />Strategy Tracker
    </a>
    <ul class="nav-links">
      <li><a href={langPaths[lang]}>{t.nav_home}</a></li>
      <li><a href={`${langPaths[lang]}#features`}>{t.nav_features}</a></li>
      <li><a href={`${langPaths[lang]}#download`}>{t.nav_download}</a></li>
    </ul>
    <select class="lang-select" id="lang-switcher" aria-label="Language">
      <option value="en" selected={lang === 'en'}>English</option>
      <option value="de" selected={lang === 'de'}>Deutsch</option>
      <option value="fr" selected={lang === 'fr'}>Français</option>
    </select>
  </div>
</nav>

<script>
  const sel = document.getElementById('lang-switcher') as HTMLSelectElement;
  const faqPaths: Record<string, string> = { en: '/faq', de: '/de/faq', fr: '/fr/faq' };
  sel?.addEventListener('change', () => { window.location.href = faqPaths[sel.value] ?? '/faq'; });
</script>

<!-- HERO -->
<section class="faq-hero">
  <h1>{page.title}</h1>
  <p>{page.subtitle}</p>
</section>

<!-- FAQ CONTENT -->
<main class="faq-body">
  {page.sections.map(section => (
    <div>
      <h2 class="faq-section-heading">{section.heading}</h2>
      {section.items.map(item => (
        <details>
          <summary>{item.q}</summary>
          <p>{item.a}</p>
        </details>
      ))}
    </div>
  ))}
</main>

<!-- DOWNLOAD -->
<DownloadSection lang={lang} />

<!-- FOOTER -->
<footer>
  <div class="footer-inner">
    <p class="footer-tagline">{t.footer_tagline}</p>
    <nav class="footer-nav">
      <a href={langPaths[lang]}>{t.nav_home}</a>
      <a href={faqPaths[lang]}>FAQ</a>
      <a href={`${langPaths[lang]}privacy`}>{lang === 'de' ? 'Datenschutz' : lang === 'fr' ? 'Confidentialité' : 'Privacy'}</a>
      <a href={`${langPaths[lang]}legal`}>{lang === 'de' ? 'Impressum' : lang === 'fr' ? 'Mentions légales' : 'Legal'}</a>
    </nav>
    <p class="footer-copy">{t.footer_copy}</p>
  </div>
</footer>

</body>
</html>
