---
import Layout from '../../components/Layout.astro';
import { getAllArticles, getArticleBySlug } from '../../lib/articles';

export async function getStaticPaths() {
  const articles = await getAllArticles('de');
  return articles.map(a => ({ params: { slug: a.slug } }));
}

const { slug } = Astro.params;
const article = await getArticleBySlug(slug, 'de');

if (!article) return Astro.redirect('/lotto');

const BASE = 'https://strategy-tracker.lawley.de';
const canonicalUrl = `${BASE}/lotto/${article.slug}`;

function formatDate(iso: string) {
  const [y, m, d] = iso.split('-');
  const months = ['', 'Januar', 'Februar', 'März', 'April', 'Mai', 'Juni',
                  'Juli', 'August', 'September', 'Oktober', 'November', 'Dezember'];
  return `${parseInt(d)}. ${months[parseInt(m)]} ${y}`;
}

const paragraphs = article.content.split(/\n\n+/).filter(Boolean);

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: article.title,
  description: article.meta_description,
  datePublished: article.draw_date,
  dateModified: article.published_at,
  url: canonicalUrl,
  inLanguage: 'de',
  author: { '@type': 'Organization', name: 'Strategy Tracker', url: BASE },
  publisher: { '@type': 'Organization', name: 'Strategy Tracker', url: BASE },
  breadcrumb: {
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Lotto 6aus49', item: `${BASE}/lotto` },
      { '@type': 'ListItem', position: 2, name: article.title, item: canonicalUrl },
    ],
  },
};
---

<Layout title={article.title} lang="de" showDownload={false} showLangSwitcher={false}>
  <link slot="head" rel="canonical" href={canonicalUrl} />
  <meta slot="head" name="description" content={article.meta_description} />
  <meta slot="head" property="og:type" content="article" />
  <meta slot="head" property="og:title" content={article.title} />
  <meta slot="head" property="og:description" content={article.meta_description} />
  <meta slot="head" property="og:url" content={canonicalUrl} />
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

  <header class="article-hero">
    <div class="article-hero-inner">
      <span class="eyebrow">Lotto 6aus49</span>
      <h2>{article.title}</h2>
      <time datetime={article.draw_date}>{formatDate(article.draw_date)}</time>
    </div>
  </header>

  <main class="article-main">
    <div class="article-container">
      <div class="article-nav">
        <a href="/lotto">← Alle Ziehungen</a>
      </div>
      <article>
        {paragraphs.map(p => <p set:html={p} />)}
      </article>
      <div class="article-footer">
        <a href="/lotto" class="back-cta">Alle Lotto 6aus49 Ziehungen &amp; Statistiken →</a>
      </div>
    </div>
  </main>
</Layout>

<style>
  .article-hero {
    background: linear-gradient(135deg, var(--brand-dark) 0%, var(--brand) 60%, var(--brand-light) 100%);
    color: white;
    padding: 40px 24px 48px;
  }
  .article-hero-inner {
    max-width: 720px;
    margin: 0 auto;
  }
  .eyebrow {
    display: inline-block;
    background: rgba(255,255,255,0.1);
    border: 1px solid rgba(255,255,255,0.18);
    border-radius: 100px;
    padding: 4px 14px;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    margin-bottom: 16px;
  }
  h2 {
    font-size: clamp(1.5rem, 3vw, 2.2rem);
    font-weight: 800;
    line-height: 1.2;
    margin: 8px 0 20px;
  }
  time {
    display: block;
    text-align: right;
    font-size: 0.8rem;
    color: rgba(255,255,255,0.45);
    font-weight: 500;
    letter-spacing: 0.03em;
  }
  .article-main {
    padding: 40px 24px 80px;
  }
  .article-container {
    max-width: 720px;
    margin: 0 auto;
  }
  .article-nav {
    display: flex;
    justify-content: flex-end;
    margin-bottom: 32px;
  }
  .article-nav a {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--brand-light);
    transition: color 0.2s;
  }
  .article-nav a:hover { color: var(--brand); }
  article p {
    margin-bottom: 1.4em;
    line-height: 1.85;
    color: var(--text);
    font-size: 1.1rem;
  }
  article p:first-child {
    color: var(--brand-light);
    font-weight: 800;
  }
  .article-footer {
    margin-top: 56px;
    padding-top: 32px;
    border-top: 1px solid var(--border);
  }
  .back-cta {
    display: inline-block;
    background: var(--brand);
    color: white;
    padding: 14px 28px;
    border-radius: var(--radius);
    font-weight: 700;
    font-size: 0.95rem;
    transition: background 0.2s, transform 0.15s;
  }
  .back-cta:hover {
    background: var(--brand-light);
    transform: translateY(-1px);
  }
</style>
