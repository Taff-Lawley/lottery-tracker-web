---
import DownloadSection from '../components/DownloadSection.astro';
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Reset Password — Strategy Tracker</title>
  <meta name="robots" content="noindex" />
  <link rel="stylesheet" href="/styles/global.css" />
  <style>
    .reset-section {
      min-height: calc(100vh - 64px);
      display: flex;
      align-items: center;
      justify-content: center;
      background: var(--bg-alt);
      padding: 48px 24px;
    }
    .card {
      background: white;
      border-radius: var(--radius);
      border: 1px solid var(--border);
      padding: 40px 36px;
      width: 100%;
      max-width: 420px;
      box-shadow: 0 4px 24px rgba(0,0,0,0.06);
    }
    .card h1 {
      font-size: 1.5rem;
      font-weight: 800;
      margin-bottom: 8px;
    }
    .subtitle {
      color: var(--text-muted);
      font-size: 0.95rem;
      margin-bottom: 28px;
    }
    label {
      display: block;
      font-size: 0.875rem;
      font-weight: 600;
      margin-bottom: 6px;
    }
    input[type="password"] {
      width: 100%;
      padding: 10px 14px;
      border: 1px solid var(--border);
      border-radius: 8px;
      font-size: 1rem;
      font-family: inherit;
      color: var(--text);
      outline: none;
      transition: border-color 0.15s;
      margin-bottom: 16px;
    }
    input[type="password"]:focus { border-color: var(--brand); }
    button[type="submit"] {
      width: 100%;
      padding: 12px;
      background: var(--brand);
      color: white;
      border: none;
      border-radius: 8px;
      font-size: 1rem;
      font-weight: 700;
      font-family: inherit;
      cursor: pointer;
      transition: background 0.15s, opacity 0.15s;
    }
    button[type="submit"]:hover { background: var(--brand-light); }
    button[type="submit"]:disabled { opacity: 0.6; cursor: not-allowed; }
    .msg {
      margin-top: 16px;
      padding: 12px 14px;
      border-radius: 8px;
      font-size: 0.9rem;
      display: none;
    }
    .msg.error   { background: #fef2f2; border: 1px solid #fca5a5; color: #b91c1c; }
    .msg.success { background: #f0fdf4; border: 1px solid #86efac; color: #15803d; }
    .centered { text-align: center; }
    .big-icon { font-size: 2.5rem; margin-bottom: 16px; }
  </style>
</head>
<body>

<nav>
  <div class="nav-inner">
    <a href="/" class="nav-logo">Strategy Tracker</a>
    <ul class="nav-links">
      <li><a href="/">Home</a></li>
      <li><a href="/#features">Features</a></li>
      <li><a href="/faq">FAQ</a></li>
    </ul>
  </div>
</nav>

<section class="reset-section">
  <div class="card">

    <div id="invalid-section" class="centered" style="display:none">
      <p class="big-icon">🔗</p>
      <h1>Link expired</h1>
      <p class="subtitle">This reset link is invalid or has already been used.<br/>Please request a new one from the app.</p>
    </div>

    <div id="form-section">
      <h1>Reset your password</h1>
      <p class="subtitle">Enter a new password for your account.</p>
      <form id="reset-form">
        <label for="password">New password</label>
        <input type="password" id="password" name="password"
               placeholder="At least 8 characters" autocomplete="new-password" required />
        <label for="confirm">Confirm password</label>
        <input type="password" id="confirm" name="confirm"
               placeholder="Repeat your new password" autocomplete="new-password" required />
        <button type="submit" id="submit-btn">Set new password</button>
      </form>
      <div id="msg" class="msg"></div>
    </div>

    <div id="success-section" class="centered" style="display:none">
      <p class="big-icon">✅</p>
      <h1>Password updated</h1>
      <p class="subtitle">You can now log in with your new password.</p>
    </div>

  </div>
</section>

<DownloadSection lang="en" />

<footer>
  <div class="footer-inner">
    <p class="footer-tagline">Lottery statistics for informed players.</p>
    <nav class="footer-nav">
      <a href="/">Home</a>
      <a href="/faq">FAQ</a>
      <a href="/privacy">Privacy</a>
      <a href="/legal">Legal</a>
    </nav>
    <p class="footer-copy">© 2026 Strategy Tracker. All rights reserved.</p>
  </div>
</footer>

<script>
  const API = 'https://lotto-ev.fly.dev';
  const token = new URLSearchParams(window.location.search).get('token');

  if (!token) {
    document.getElementById('form-section')!.style.display = 'none';
    document.getElementById('invalid-section')!.style.display = 'block';
  }

  document.getElementById('reset-form')?.addEventListener('submit', async (e) => {
    e.preventDefault();

    const password = (document.getElementById('password') as HTMLInputElement).value;
    const confirm  = (document.getElementById('confirm')  as HTMLInputElement).value;
    const msg      = document.getElementById('msg')!;
    const btn      = document.getElementById('submit-btn') as HTMLButtonElement;

    msg.style.display = 'none';

    if (password !== confirm) {
      msg.textContent = 'Passwords do not match.';
      msg.className = 'msg error';
      msg.style.display = 'block';
      return;
    }
    if (password.length < 8) {
      msg.textContent = 'Password must be at least 8 characters.';
      msg.className = 'msg error';
      msg.style.display = 'block';
      return;
    }

    btn.disabled = true;
    btn.textContent = 'Updating…';

    try {
      const res = await fetch(`${API}/auth/reset-password`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ token, password }),
      });

      if (res.status === 204) {
        document.getElementById('form-section')!.style.display = 'none';
        document.getElementById('success-section')!.style.display = 'block';
        return;
      }

      const data = await res.json().catch(() => ({}));
      msg.textContent = (data as any).detail ?? 'Something went wrong. Please try again.';
      msg.className = 'msg error';
      msg.style.display = 'block';
    } catch {
      msg.textContent = 'Network error. Please check your connection.';
      msg.className = 'msg error';
      msg.style.display = 'block';
    } finally {
      btn.disabled = false;
      btn.textContent = 'Set new password';
    }
  });
</script>

</body>
</html>
